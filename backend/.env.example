# Daedalus AI — Backend Environment Variables

# ── Gemini API (Person A: agents, domain classifier, critique, scoring) ───────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Anthropic Claude API (Person B: wireframe_gen HTML generation) ────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
